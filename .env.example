# Market Analyzer Pro v2 — Environment Variables
# Скопируйте в .env и заполните значения

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://analyzer:changeme@localhost:5432/market_analyzer
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Keys (обязательные, бесплатные) ───────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
# Finnhub: https://finnhub.io/register
FINNHUB_KEY=
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=

# ── API Keys (рекомендуемые, бесплатные) ──────────────
# Polygon.io: https://polygon.io (US Stocks)
POLYGON_API_KEY=
# Reddit: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MarketAnalyzerPro/2.0
# Glassnode: https://studio.glassnode.com (DEPRECATED — $999/mo, use CryptoQuant/CoinGecko)
# GLASSNODE_API_KEY=
# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=

# ── API Keys (опциональные) ──────────────────────────
# Anthropic Claude: https://console.anthropic.com (LLM validation)
ANTHROPIC_API_KEY=
# LLM validation gate (requires ANTHROPIC_API_KEY): true/false
LLM_VALIDATION_ENABLED=true

# ── Telegram (алерты) ─────────────────────────────────
# @BotFather в Telegram
TELEGRAM_BOT_TOKEN=
# ID чата для алертов
TELEGRAM_CHAT_ID=

# ── Webhook интеграции ────────────────────────────────
# MetaTrader 5 Expert Advisor webhook URL
WEBHOOK_MT5_URL=
# 3Commas Bot API webhook URL
WEBHOOK_3COMMAS_URL=
# TradingView alert webhook URL
WEBHOOK_TRADINGVIEW_URL=

# ── FinBERT Service ───────────────────────────────────
FINBERT_SERVICE_URL=http://finbert:8001

# ── Collector Intervals ───────────────────────────────
CRYPTO_PRICE_INTERVAL_SECONDS=60
FOREX_PRICE_INTERVAL_MINUTES=15
STOCK_PRICE_INTERVAL_MINUTES=15
ORDER_FLOW_INTERVAL_MINUTES=5
NEWS_COLLECT_INTERVAL_MINUTES=10
SOCIAL_COLLECT_INTERVAL_MINUTES=30
MACRO_COLLECT_INTERVAL_HOURS=24
ONCHAIN_COLLECT_INTERVAL_HOURS=6
REGIME_DETECT_INTERVAL_MINUTES=60

# ── Signal Engine (default weights, overridden by RegimeDetector) ──
DEFAULT_TA_WEIGHT=0.45
DEFAULT_FA_WEIGHT=0.25
DEFAULT_SENTIMENT_WEIGHT=0.20
DEFAULT_GEO_WEIGHT=0.10

# ── Signal Thresholds (calibrated to real composite range ≈ ±25) ──
STRONG_BUY_THRESHOLD=15.0
BUY_THRESHOLD=7.0
SELL_THRESHOLD=-7.0
STRONG_SELL_THRESHOLD=-15.0
MIN_CONFIDENCE=10.0

# ── LLM Validation (v3) ────────────────────────────
# Score threshold for triggering LLM validation (v2 was 25 = never triggered)
LLM_SCORE_THRESHOLD=10.0

# ── Risk Management ──────────────────────────────────
SL_ATR_MULTIPLIER=1.5
TP1_RR=2.0
TP2_RR=3.5
TP3_RR=4.0
MAX_RISK_PER_TRADE_PCT=2.0
CORRELATION_THRESHOLD=0.7
MAX_PORTFOLIO_HEAT=6.0
MAX_OPEN_FOREX=3
MAX_OPEN_CRYPTO=2
MAX_OPEN_STOCKS=5

# ── Account Size (v3) ──────────────────────────────
# Account size for signal position size calculation (was hardcoded $10k)
SIGNAL_ACCOUNT_SIZE_USD=10000.0
# Account size for virtual portfolio simulator (was hardcoded $1k)
VIRTUAL_ACCOUNT_SIZE_USD=1000.0

# ── Backtesting ──────────────────────────────────────
BACKTEST_IN_SAMPLE_MONTHS=18
BACKTEST_OUT_OF_SAMPLE_MONTHS=6
MONTE_CARLO_SIMULATIONS=10000
MIN_OOS_TRADES=30
MIN_OOS_SHARPE=0.8
MIN_OOS_PROFIT_FACTOR=1.3

# ── Tracker ──────────────────────────────────────────
TRACKER_CHECK_INTERVAL_MINUTES=5
SIGNAL_EXPIRY_HOURS=168
EARNINGS_SKIP_DAYS=2
EARNINGS_DISCOUNT_DAYS=5

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# ── Grafana ──────────────────────────────────────────
GRAFANA_PASSWORD=admin
