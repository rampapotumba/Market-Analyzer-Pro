# Market Analyzer Pro — Environment Variables
# Скопируйте в .env и заполните значения

# ── Database ──────────────────────────────────────────
# SQLite (Phase 1):
DATABASE_URL=sqlite+aiosqlite:///./data/market_analyzer.db
# PostgreSQL (Phase 2):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/market_analyzer

# ── API Keys (бесплатные) ────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Finnhub: https://finnhub.io/register
FINNHUB_KEY=

# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=

# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=

# ── Telegram (для алертов, Phase 3) ──────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Collector Settings ────────────────────────────────
PRICE_COLLECT_INTERVAL_MINUTES=5
NEWS_COLLECT_INTERVAL_MINUTES=15
MACRO_COLLECT_INTERVAL_HOURS=24

# ── Signal Engine Weights ─────────────────────────────
# Веса зависят от стиля торговли. По умолчанию: Swing (H4)
TA_WEIGHT=0.45
FA_WEIGHT=0.25
SENTIMENT_WEIGHT=0.20
GEO_WEIGHT=0.10

# ── Risk Management ──────────────────────────────────
SL_ATR_MULTIPLIER=1.5
TP1_ATR_MULTIPLIER=2.0
TP2_ATR_MULTIPLIER=3.5
MAX_RISK_PER_TRADE_PCT=2.0
CORRELATION_THRESHOLD=0.7

# ── Signal Thresholds ────────────────────────────────
STRONG_BUY_THRESHOLD=60.0
BUY_THRESHOLD=30.0
SELL_THRESHOLD=-30.0
STRONG_SELL_THRESHOLD=-60.0

# ── Tracker ──────────────────────────────────────────
TRACKER_CHECK_INTERVAL_MINUTES=5
SIGNAL_EXPIRY_HOURS=168

# ── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
